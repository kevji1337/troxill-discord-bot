DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN
CLIENT_ID=YOUR_APPLICATION_CLIENT_ID
GUILD_ID=YOUR_TEST_GUILD_ID

LOG_CHANNEL_ID=
TICKET_CATEGORY_ID=

MODERATOR_ROLE_IDS=
PING_ROLE_IDS=
TICKET_VIEW_ROLE_IDS=

CURATOR_ROLE_ID=
MEDIA_MANAGER_ROLE_ID=
TICKET_PANEL_OWNER_ID=
STATUS_PANEL_OWNER_ID=

GOOGLE_DRIVE_WEBAPP_URL=
ENABLE_EXTERNAL_TICKET_EXPORT=false

# false by default to avoid copying third-party media into transcripts.
TRANSCRIPT_SAVE_IMAGES=false
DM_TICKET_TRANSCRIPTS=false
DM_TICKET_FEEDBACK=true

# -1 = no limit, but large transcripts may hit memory/rate limits.
TRANSCRIPT_LIMIT=2000

# ----- CAMPAIGN & WEB ADMIN CONFIGS -----
PORT=1784
HOST=0.0.0.0
ADMIN_BASE_URL=http://localhost:1784

DISCORD_OAUTH_CLIENT_ID=YOUR_DISCORD_OAUTH_CLIENT_ID
DISCORD_OAUTH_CLIENT_SECRET=YOUR_DISCORD_OAUTH_CLIENT_SECRET
DISCORD_OAUTH_REDIRECT_URI=http://localhost:1784/api/auth/callback

SESSION_SECRET=YOUR_SESSION_SECRET_KEY

# Comma-separated list of Discord User IDs allowed to access the admin panel
ADMIN_DISCORD_IDS=1234567890,0987654321

CAMPAIGN_DEFAULT_DELAY_MS=2000
CAMPAIGN_MAX_ATTEMPTS=3

